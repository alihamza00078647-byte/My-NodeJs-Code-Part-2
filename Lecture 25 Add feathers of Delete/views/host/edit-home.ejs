<%- include('../partials/head') %>

<link rel="stylesheet" href="Homesdetails.css">


</head>
<body>
    <%- include('../partials/nav') %>
    <h1 style="text-align: center;" ><%= editing ? "Edit" : "Register"%> your Home on airbnb</h1>
    <form action="/host/<%= editing ? 'edit-home' : 'add-home'%>" method="post">
        <input type="hidden" name="id" value="<%= editing ? home.id : '' %>">
        <input type="text" name="houseName" placeholder="Enter House Name" value="<%= editing ? home.houseName : '' %>">    
        <input type="text" name="price" placeholder="House Price" value="<%= editing ? home.price : '' %>">    
        <input type="text" name="location" placeholder="Enter Location" value="<%= editing ? home.location : '' %>">    
        <input type="text" name="rating" placeholder="Rating on your Experience" value="<%= editing ? home.rating : '' %>"> 
        <input type="text" name="photoUrl" placeholder="Paste Url" value="<%= editing ? home.photoUrl : '' %>"> 
        <button class="btn" type="submit"><%= editing ? 'Update details' : 'Register home'%></button>
    </form>
</body>
</html>