
<link rel="stylesheet" href="/output.css">

</head>
<body>
    <div class="bg-amber-500 p-5 flex gap-7">
        <a class="text-xl text-amber-50 font-medium" href="/">airbnb</a>
        <% if (isLoggedIn) { %>
            
        <a class="text-xl text-amber-50 font-medium" href="/home">home</a>
        <a class="text-xl text-amber-50 font-medium" href="/bookings">bookings</a>
        <a class="text-xl text-amber-50 font-medium" href="/favourite">favourite</a>
        <a class="text-xl text-amber-50 font-medium" href="/host/addhomes">Add homes</a>
        <a class="text-xl text-amber-50 font-medium" href="/host/hosthomepage">hosthomepage</a>
        <% } %>

        <% if (!isLoggedIn) { %>
            <a class="text-xl text-amber-50 font-medium" href="/login">Login</a>
            
            <a href="/signup" class="text-xl text-amber-50 font-medium">Signup</a>

        <% } else { %>
            <form action="/logout" method="post">
                <button type="submit" 
                class="text-xl text-amber-50 font-medium cursor-pointer">Logout</button>
            </form>
        <% } %>
    </div>
</body>
</html>