<%- include('../partials/head') %>


<link rel="stylesheet" href="/css/eachhomedetails.css">
</head>
<body>
    <%- include('../partials/nav') %>
    <h2 style="text-align: center; margin-top: 0.5rem; color : #23B5D3;"> <%=Home.houseName %> Home Details</h2>

    <div class="details-container">
    <div class="details-card">
        <div class="details-image">
            <img src="<%= Home.photo %>" alt="<%= Home.houseName %>">
        </div>

        <div class="details-content">
            <nav class="breadcrumb">Home / Listings / <%= Home.houseName %></nav>
            
            <h1><%= Home.houseName %></h1>
            <p class="details-location">📍 <%= Home.location %></p>
            
            <hr>

            <div class="details-meta">
                <span class="details-price">$<%= Home.price %></span>
                <span class="details-rating">⭐ <%= Home.rating %> / 5.0</span>
            </div>

            <div class="details-description">
                <h3>About this property</h3>
                <p><%= Home.description %></p>
            </div>

            

            <div class="action-buttons">
                <a href="/favourite/<%=Home._id%>" class="btn-primary">favourite</a>
                <button class="btn-secondary">Contact Host</button>
            </div>

            <div class="pdffileOption">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14 2H6C4.89543 2 4 2.89543 4 4V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V8L14 2Z" 
                            fill="#2563eb" />
                    
                    <path d="M14 2V8H20L14 2Z" fill="#60a5fa" />
                    
                    <text x="7" y="17" fill="white" font-family="Arial, Helvetica, sans-serif" font-weight="bold" font-size="5px">PDF</text>
                </svg>
                <a href="/rules/<%= Home._id %>">Download House Rules</a>
            </div>

            </div>
        </div>
    </div>
    
</body>
</html>